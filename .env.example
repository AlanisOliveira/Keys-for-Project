PORT=3210
APP_IMAGE=ghcr.io/alanisoliveira/security-alanis:latest
DATA_PATH=/DATA/AppData/security-alanis/db
DB_PATH=/data/vault.db

# At least 32 random characters — generate with: openssl rand -base64 32
SESSION_SECRET=replace_with_32_char_minimum_random_string

# Admin credentials used only by the seed script (can be removed after first run)
ADMIN_CPF=00000000000
ADMIN_PASSWORD=change_this_strong_password

# Public app URL (used for redirect links shown to clients)
NEXT_PUBLIC_APP_URL=http://localhost:3210

NODE_ENV=production
